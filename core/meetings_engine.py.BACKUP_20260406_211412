import json
import os
from datetime import datetime

FILE = "meetings.json"


class MeetingsEngine:

    def _load(self):
        if not os.path.exists(FILE):
            return []
        with open(FILE, "r") as f:
            return json.load(f)

    def _save(self, data):
        with open(FILE, "w") as f:
            json.dump(data, f, indent=2)

    def add_meeting(self, title, time_value, notes=""):

        meetings = self._load()

        item = {
            "id": f"m_{int(datetime.utcnow().timestamp())}",
            "title": title,
            "time": time_value,
            "notes": notes,
            "created_at": datetime.utcnow().isoformat()
        }

        meetings.append(item)

        # ordenar por hora
        meetings = sorted(meetings, key=lambda x: x.get("time", "99:99"))

        self._save(meetings)

        return item

    def get_meetings(self):

        meetings = self._load()

        # ordenar por hora siempre
        meetings = sorted(meetings, key=lambda x: x.get("time", "99:99"))

        return meetings
