<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
  <title>JARVIS // Command Center</title>
  <style>
    :root{
      --bg:#07111a;
      --card:#0b1723;
      --card2:#112235;
      --line:rgba(83,225,255,.14);
      --cyan:#89f7ff;
      --cyan2:#44f0ff;
      --white:#eef8ff;
      --soft:#9fb5c8;
      --ok:#49ffc2;
      --warn:#ffd45a;
      --bad:#ff6b6b;
      --shadow:0 18px 40px rgba(0,0,0,.28);
      --radius:24px;
    }
    *{box-sizing:border-box}
    body{
      margin:0;
      font-family: Inter, system-ui, Arial, sans-serif;
      background:
        radial-gradient(circle at top left, rgba(68,240,255,.12), transparent 24%),
        linear-gradient(180deg, #08131d 0%, #050c13 100%);
      color:var(--white);
      min-height:100vh;
    }
    .shell{max-width:1500px;margin:0 auto;padding:18px}
    .topbar{display:grid;grid-template-columns:1.2fr .8fr;gap:18px;margin-bottom:18px}
    .hero,.quick,.card{
      background:linear-gradient(180deg, rgba(10,22,34,.98), rgba(7,16,25,.98));
      border:1px solid var(--line);
      border-radius:28px;
      box-shadow:var(--shadow);
    }
    .hero{padding:24px;display:flex;justify-content:space-between;align-items:center;gap:18px}
    .hero-left{display:flex;gap:18px;align-items:center}
    .orb{
      width:84px;height:84px;border-radius:50%;
      background: radial-gradient(circle, rgba(28,231,255,1) 0%, rgba(28,231,255,.46) 18%, rgba(9,22,34,.2) 58%, rgba(0,0,0,0) 72%);
      box-shadow:0 0 28px rgba(28,231,255,.55), inset 0 0 26px rgba(28,231,255,.25);
    }
    h1{margin:0;font-size:56px;line-height:1}
    .subtitle{margin-top:8px;color:var(--cyan);font-size:20px}
    .meta{margin-top:12px;color:var(--soft);display:flex;flex-wrap:wrap;gap:12px;font-size:14px}
    .header-actions{display:flex;align-items:center;gap:12px}
    .primary-btn,.ghost-btn{
      border:none;border-radius:18px;padding:14px 16px;cursor:pointer;font-weight:700;
    }
    .ghost-btn{background:var(--card2);color:var(--white);border:1px solid rgba(255,255,255,.06)}
    .primary-btn{background:linear-gradient(180deg, var(--cyan2), #0fb8dd);color:#06202a}
    .status-chip{
      display:inline-flex;align-items:center;gap:8px;padding:12px 16px;
      border-radius:999px;border:1px solid rgba(28,231,255,.22);color:var(--cyan);font-weight:700;
    }
    .status-dot{width:10px;height:10px;border-radius:50%;background:var(--ok);box-shadow:0 0 10px var(--ok)}
    .quick{padding:18px;display:grid;grid-template-columns:repeat(2,1fr);gap:12px}
    .quick-card{padding:16px 18px;border-radius:22px;background:var(--card2);border:1px solid rgba(255,255,255,.05)}
    .quick-label{font-size:12px;color:var(--soft);text-transform:uppercase;letter-spacing:.14em;margin-bottom:10px}
    .quick-value{font-size:28px;font-weight:800;line-height:1.2}
    .main{display:grid;grid-template-columns:1.05fr .95fr;gap:18px}
    .col{display:grid;gap:18px;align-content:start}
    .card{padding:18px;border-radius:28px}
    .section-top{display:flex;justify-content:space-between;align-items:center;gap:12px;margin-bottom:14px}
    .section-title{margin:0;font-size:32px;color:var(--cyan)}
    .subtle{color:var(--soft);font-size:14px}
    .command-bar{display:grid;grid-template-columns:1fr auto auto auto;gap:10px;align-items:center}
    .input,.select{
      width:100%;border:none;outline:none;border-radius:18px;background:var(--card2);color:var(--white);
      padding:16px 18px;font-size:16px;border:1px solid rgba(255,255,255,.05)
    }
    .chat-log{margin-top:14px;display:grid;gap:12px;max-height:260px;overflow:auto;padding-right:4px}
    .bubble{padding:14px 16px;border-radius:18px;line-height:1.5;font-size:15px;white-space:pre-wrap}
    .bubble.user{background:#16344d;border:1px solid rgba(28,231,255,.15)}
    .bubble.jarvis{background:var(--card2);border:1px solid rgba(76,255,198,.10)}
    .stack{display:grid;gap:12px}
    .row-card,.brief{
      padding:14px;border-radius:18px;background:var(--card2);border:1px solid rgba(255,255,255,.05)
    }
    .row-title{font-weight:700;font-size:15px}
    .row-sub{font-size:13px;color:var(--soft);margin-top:4px}
    .task-item{display:flex;justify-content:space-between;gap:10px;align-items:flex-start}
    .check-btn{
      width:22px;height:22px;border-radius:8px;border:1px solid rgba(255,255,255,.12);
      background:#102030;color:var(--ok);cursor:pointer
    }
    .add-inline{display:grid;grid-template-columns:1fr 130px 110px auto;gap:10px;margin-top:12px}
    .add-inline.meeting{grid-template-columns:1fr 120px 1fr auto}
    .market-head{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
    .metric{padding:14px;border-radius:20px;background:var(--card2);border:1px solid rgba(255,255,255,.05)}
    .metric-label{font-size:12px;color:var(--soft);text-transform:uppercase;letter-spacing:.12em;margin-bottom:10px}
    .metric-value{font-size:28px;font-weight:800}
    .trader-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:12px}
    .asset-grid,.recommendations,.results-grid{display:grid;gap:12px}
    .asset,.result-card{
      padding:14px;border-radius:18px;background:var(--card2);border:1px solid rgba(255,255,255,.05)
    }
    .asset .name{font-weight:700;margin-bottom:6px;word-break:break-word}
    .asset .meta{margin:0;color:var(--soft);font-size:12px}
    .asset a{display:inline-block;margin-top:8px;color:var(--cyan);text-decoration:none}
    .upload-zone{
      border:1.5px dashed rgba(28,231,255,.28);background:linear-gradient(180deg, rgba(10,24,38,.78), rgba(9,18,29,.88));
      border-radius:22px;padding:22px;text-align:center;color:var(--soft);cursor:pointer
    }
    .upload-input{display:none}
    .tag-ok,.tag-warn,.tag-bad{
      display:inline-flex;align-items:center;padding:8px 12px;border-radius:999px;font-size:13px;font-weight:700
    }
    .tag-ok{background:rgba(73,255,194,.12);color:var(--ok)}
    .tag-warn{background:rgba(255,212,90,.12);color:var(--warn)}
    .tag-bad{background:rgba(255,107,107,.12);color:var(--bad)}
    .result-empty{
      padding:18px;border-radius:18px;background:var(--card2);border:1px dashed rgba(255,255,255,.08);color:var(--soft)
    }
    .news-title{font-weight:700;margin-bottom:6px}
    .news-source{font-size:12px;color:var(--soft)}
    .result-title{font-size:20px;font-weight:800}
    .pill-row{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px}
    @media (max-width: 1280px){
      .topbar,.main{grid-template-columns:1fr}
    }
    @media (max-width: 860px){
      .hero{flex-direction:column;align-items:flex-start}
      .market-head,.trader-grid{grid-template-columns:1fr}
      .command-bar{grid-template-columns:1fr}
      .add-inline,.add-inline.meeting{grid-template-columns:1fr}
      .shell{padding:12px}
    }
  
  /* ===== OPS-X PRO LAYER ===== */

  .asset-type-stock { border-left: 4px solid #44f0ff; }
  .asset-type-crypto { border-left: 4px solid #ffd45a; }
  .asset-type-etf { border-left: 4px solid #49ffc2; }

  .result-card.top-pick {
    border: 1px solid rgba(73,255,194,.4);
    box-shadow: 0 0 20px rgba(73,255,194,.15);
  }

  .recent-bar {
    display:flex;
    gap:8px;
    flex-wrap:wrap;
    margin-top:10px;
  }

  .recent-item {
    padding:6px 10px;
    border-radius:10px;
    background:var(--card2);
    border:1px solid rgba(255,255,255,.05);
    cursor:pointer;
    font-size:12px;
  }

</style>
</head>
<body>
  <div class="shell">
    <div class="topbar">
      <section class="hero">
