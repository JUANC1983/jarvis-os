<script>

let recentSymbols = [];

function detectAssetType(symbol){
  if(!symbol) return "stock";
  symbol = symbol.toUpperCase();

  if(["BTC","ETH","SOL","XRP"].includes(symbol)) return "crypto";
  if(["SPY","QQQ","XLE","USO"].includes(symbol)) return "etf";

  return "stock";
}

function saveRecent(symbol){
  if(!symbol) return;
  recentSymbols = [symbol, ...recentSymbols.filter(s => s !== symbol)].slice(0,8);
}

  const qs = (id) => document.getElementById(id);
  const state = { recognition: null, listening: false };

  function addBubble(text, who="jarvis"){
    const div = document.createElement("div");
    div.className = "bubble " + who;
    div.textContent = text;
    qs("chatLog").appendChild(div);
    qs("chatLog").scrollTop = qs("chatLog").scrollHeight;
  }

  function trafficTag(level){
    const v = (level || "").toLowerCase();
    if(v === "green") return `<span class="tag-ok">? Go</span>`;
    if(v === "yellow") return `<span class="tag-warn">? Wait</span>`;
    return `<span class="tag-bad">? Avoid</span>`;
  }

  async function loadHome(){
    const res = await fetch("/dashboard/home");
    const data = await res.json();

    qs("greeting").textContent = data.greeting || "JARVIS ready";
    qs("todayDate").textContent = data.date || "--";
    qs("ownerName").textContent = "Owner: " + (data.owner_name || "Juan Camilo");
    qs("topPriority").textContent = data.top_priority || "Protect capital";
    qs("tasksOpen").textContent = data.tasks_open || 0;
    qs("assetsCount").textContent = data.assets_count || 0;

    if(data.next_meeting){
      qs("nextMeeting").textContent = `${data.next_meeting.time} � ${data.next_meeting.title}`;
    } else {
      qs("nextMeeting").textContent = "No meetings";
    }

    renderTasks(data.tasks || []);
    renderMeetings(data.meetings || []);
  }

  function renderTasks(items){
    const box = qs("tasksList");
    box.innerHTML = "";
    if(!items.length){
      box.innerHTML = `<div class="brief">No tasks yet.</div>`;
      return;
    }

    let html = "";

items.forEach((item, i) => {
    html += renderStockCard(item, i);
});

box.innerHTML = html;
  }

  async function loadAssets(){
    const res = await fetch("/dashboard/assets");
    const data = await res.json();
    const items = data.assets || [];
    qs("assetsCount").textContent = items.length;

    const box = qs("assetGrid");
    box.innerHTML = "";
    if(!items.length){
      box.innerHTML = `<div class="brief">No assets uploaded yet.</div>`;
      return;
    }

    items.slice(0,8).forEach(asset => {
      const div = document.createElement("div");
      div.className = "asset";
      div.innerHTML = `
        <div class="name">${asset.filename}</div>
        <div class="meta">${asset.kind} � ${asset.mime_type || "unknown"}</div>
        <a href="/dashboard/uploads/${asset.filename}" target="_blank">Open file</a>
      `;
      box.appendChild(div);
    });
  }

  async function uploadFiles(files){
    for(const file of files){
      const form = new FormData();
      form.append("file", file);
      await fetch("/dashboard/upload", {method:"POST", body:form});
    }
    await loadAssets();
    await loadHome();
  }

  function initUpload(){
    const zone = qs("uploadZone");
    const input = qs("fileInput");

    zone.onclick = () => input.click();

    input.onchange = async (e) => {
      if(e.target.files?.length) await uploadFiles(e.target.files);
    };

    zone.addEventListener("dragover", e => {
      e.preventDefault();
    });

    zone.addEventListener("drop", async e => {
      e.preventDefault();
      const files = e.dataTransfer?.files;
      if(files?.length) await uploadFiles(files);
    });
  }

  function initEvents(){
    qs("sendBtn").onclick = () => sendChat();
    qs("chatInput").addEventListener("keydown", e => {
      if(e.key === "Enter") sendChat();
    });
    qs("addTaskBtn").onclick = addTask;
    qs("addMeetingBtn").onclick = addMeeting;
    qs("analyzeBtn").onclick = analyzeTrader;
    qs("autoBtn").onclick = runAutoJarvis;
  }

  async function boot(){
    initEvents();
    initVoice();
    initUpload();
    await loadHome();
    await loadAssets();
    await analyzeTrader();
    await loadRecommendations();
  }

  boot();
</script>
</body>
