<script>

function renderStockCard(item, rank=null) {

    const symbol = item.symbol || "-";
    const price = item.price || "-";
    const score = item.setup_score || 0;
    const plan = item.trade_plan || {};

    const sector = item.sector || "unknown";
    const region = item.region || "usa";
    const asset_type = item.asset_type || "stock";

    let medal = "";
    if (rank === 0) medal = "🥇";
    if (rank === 1) medal = "🥈";
    if (rank === 2) medal = "🥉";

    let color = "white";
    if (score >= 80) color = "lime";
    else if (score >= 60) color = "orange";
    else color = "red";

    return `
    <div class="result-card ${rank === 0 ? 'top-pick' : ''}">
        <div style="display:flex;justify-content:space-between">
            <strong>${medal} ${symbol}</strong>
            <span style="color:${color}">${score}</span>
        </div>

        <div style="margin-top:6px;font-size:12px;color:var(--soft)">
            ${sector.toUpperCase()} | ${region.toUpperCase()} | ${asset_type.toUpperCase()}
        </div>

        <div style="margin-top:8px">Precio: ${price}</div>

        <div style="margin-top:6px;font-size:13px">
            Entry: ${plan.entry_zone || "-"}<br>
            Stop: ${plan.stop_loss || "-"}<br>
            Target: ${plan.target_1 || "-"} / ${plan.target_2 || "-"}
        </div>
    </div>
    `;
}